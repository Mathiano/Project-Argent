    },
    {
      "type": "npc",
      "x": 7,
      "y": 4,
      "color": "#c2491a",
      "blockedUntilFlag": "route31_trainer_beaten",
      "approachOnEnter": true,
      "interact": [
        {
          "kind": "dialog",
          "lines": [
            "JAY: That's a sharp little",
            "partner. Out here, what is",
            "yours is mine — hand it over,",
            "or I TAKE it!"
          ]
        },
        {
          "kind": "start-trainer-battle",
          "foeSpecies": "FLITPECK",
          "winFlag": "route31_trainer_beaten",
          "reward": 500
